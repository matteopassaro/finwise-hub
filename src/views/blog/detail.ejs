<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="flex-1">
  <div class="bg-gray-50 dark:bg-dark-800 border-b border-gray-200 dark:border-gray-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex text-sm text-gray-500">
        <a href="/" class="hover:text-brand-600">Home</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-brand-600">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900 dark:text-white font-medium truncate"><%= post.title.split('–')[0] %></span>
      </nav>
    </div>
  </div>

  <article class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="badge-blue"><%= post.category %></span>
          <span class="text-sm text-gray-400"><%= post.readTime %> min lettura</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-display font-bold text-gray-900 dark:text-white mb-4 text-balance"><%= post.title %></h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-4"><%= post.excerpt %></p>
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <div class="w-8 h-8 bg-brand-100 dark:bg-brand-900 rounded-full flex items-center justify-center text-brand-600 dark:text-brand-400 font-bold text-xs">FW</div>
          <span><%= post.author %></span>
          <span>·</span>
          <time datetime="<%= post.date %>"><%= new Date(post.date).toLocaleDateString('it-IT', {day:'2-digit',month:'long',year:'numeric'}) %></time>
        </div>
      </header>

      <div class="prose-custom">
        <%- post.content %>
      </div>

      <!-- Tags -->
      <div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-700">
        <div class="flex flex-wrap gap-2">
          <% post.tags.forEach(tag => { %>
          <span class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-3 py-1">#<%= tag %></span>
          <% }) %>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-10 card p-8 text-center bg-gradient-to-r from-brand-50 to-finance-50 dark:from-brand-950 dark:to-finance-950 border-brand-200 dark:border-brand-800">
        <h3 class="text-xl font-display font-bold text-gray-900 dark:text-white mb-2">Vuoi iniziare a guadagnare?</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Scopri tutti i bonus attivi e inizia a risparmiare oggi stesso.</p>
        <a href="/bonus" class="btn-primary">Vedi tutti i bonus →</a>
      </div>
    </div>
  </article>
</main>

<%- include('../partials/footer') %>
