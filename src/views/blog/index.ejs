<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="flex-1">
  <section class="bg-gray-50 dark:bg-dark-800 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title text-3xl md:text-4xl">Blog</h1>
      <p class="section-subtitle">Guide, confronti e strategie per massimizzare i tuoi guadagni dai bonus bancari.</p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% blogPosts.forEach(post => { %>
        <a href="/blog/<%= post.slug %>" class="blog-card group">
          <div class="h-44 bg-gradient-to-br from-brand-500 to-finance-500 group-hover:from-brand-600 group-hover:to-finance-600 transition-all flex items-center justify-center p-6">
            <span class="text-white font-display font-bold text-lg text-center leading-tight"><%= post.title.split('–')[0] %></span>
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="badge-blue"><%= post.category %></span>
              <span class="text-xs text-gray-400"><%= post.readTime %> min</span>
            </div>
            <h2 class="font-display font-bold text-gray-900 dark:text-white mb-2 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors"><%= post.title %></h2>
            <p class="text-sm text-gray-500 line-clamp-3 mb-3"><%= post.excerpt %></p>
            <div class="flex items-center gap-2 text-xs text-gray-400">
              <span><%= post.author %></span>
              <span>·</span>
              <span><%= new Date(post.date).toLocaleDateString('it-IT', {day:'2-digit',month:'long',year:'numeric'}) %></span>
            </div>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
