<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<%- '<style>' %>
  <% promos.forEach((promo, i) => { %>
  .promo-item-<%= i %> { --promo-color: <%= promo.color %>; }
  <% }) %>
<%- '</style>' %>

<main class="flex-1">
  <!-- Header -->
  <section class="bg-gray-50 dark:bg-dark-800 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title text-3xl md:text-4xl">Tutti i Bonus e Referral Attivi</h1>
      <p class="section-subtitle">Confronta, filtra e scegli le promozioni migliori per te. Aggiornato a Maggio 2026.</p>
    </div>
  </section>

  <!-- Filters + Table -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filters -->
      <div class="flex flex-wrap gap-2 mb-8">
        <button data-filter="all" class="badge bg-brand-100 dark:bg-brand-900 text-brand-700 dark:text-brand-300 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer active">Tutti</button>
        <button data-filter="Facile" class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-brand-50">Facile</button>
        <button data-filter="Molto facile" class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-brand-50">Molto facile</button>
        <button data-filter="Media" class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-brand-50">Media</button>
      </div>

      <!-- Grid di Card (Sostituisce la tabella) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="bonus-grid">
        <% promos.forEach((promo, i) => { %>
        <div class="card-promo promo-item-<%= i %> group flex flex-col h-full" data-difficulty="<%= promo.difficulty %>" data-name="<%= promo.name.toLowerCase() %>">
          <div class="absolute top-0 left-0 right-0 h-1" style="background: var(--promo-color)"></div>
          
          <div class="flex-1 p-6">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-sm" style="background: var(--promo-color)">
                  <%= promo.shortName.charAt(0) %>
                </div>
                <div>
                  <h3 class="font-display font-bold text-gray-900 dark:text-white text-lg leading-tight group-hover:text-brand-600 transition-colors"><%= promo.name %></h3>
                  <div class="text-xs text-gray-500 font-medium"><%= promo.bank %></div>
                </div>
              </div>
              <span class="badge-green text-[10px] whitespace-nowrap"><%= promo.difficulty %></span>
            </div>

            <div class="mb-4">
              <div class="text-sm text-gray-500 mb-1">Bonus di benvenuto</div>
              <div class="text-3xl font-display font-bold text-finance-600 dark:text-finance-400">
                <%= promo.bonusAmount %>€
              </div>
              <div class="text-xs font-medium text-gray-500 bg-gray-100 dark:bg-gray-800 inline-block px-2 py-1 rounded-md mt-2">
                <%= promo.bonusType %>
              </div>
            </div>

            <div class="space-y-3 mb-6">
              <div class="text-sm font-medium text-gray-900 dark:text-white">Cosa devi fare:</div>
              <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
                <% promo.requirements.slice(0, 2).forEach(r => { %>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-finance-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="leading-snug"><%= r %></span>
                </li>
                <% }) %>
                <% if (promo.requirements.length > 2) { %>
                <li class="text-xs text-gray-400 italic pl-7">+ altri requisiti...</li>
                <% } %>
              </ul>
            </div>
          </div>

          <div class="p-6 pt-0 mt-auto border-t border-gray-100 dark:border-gray-800 flex flex-col gap-3">
            <div class="flex items-center justify-between text-xs text-gray-500 mb-2">
              <span>Scadenza: <strong class="text-gray-900 dark:text-gray-300"><%= new Date(promo.validTo).toLocaleDateString('it-IT') %></strong></span>
              <% if (promo.referralCode) { %>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                Codice attivo
              </span>
              <% } %>
            </div>
            <div class="flex gap-2">
              <% if (promo.referralCode) { %>
              <button class="copy-btn flex-1 justify-center py-2.5 bg-gray-50 hover:bg-gray-100 dark:bg-dark-800 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium rounded-xl transition-colors border border-gray-200 dark:border-gray-700" data-copy="<%= promo.referralCode %>">
                <span class="copy-code-text"><%= promo.referralCode %></span>
              </button>
              <% } %>
              <a href="/bonus/<%= promo.slug %>" class="btn-primary flex-1 text-center py-2.5">Scopri la guida →</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Messaggio nessun risultato -->
      <div id="no-results" class="hidden text-center py-12">
        <div class="w-16 h-16 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Nessun bonus trovato</h3>
        <p class="text-gray-500">Prova a cambiare i filtri di ricerca.</p>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
