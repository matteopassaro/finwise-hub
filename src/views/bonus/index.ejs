<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
  <% promos.forEach((promo, i) => { %>
  .promo-item-<%= i %> { --promo-color: <%= promo.color %>; }
  <% }) %>
</style>

<main class="flex-1">
  <!-- Header -->
  <section class="bg-gray-50 dark:bg-dark-800 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title text-3xl md:text-4xl">Tutti i Bonus e Referral Attivi</h1>
      <p class="section-subtitle">Confronta, filtra e scegli le promozioni migliori per te. Aggiornato a Maggio 2026.</p>
    </div>
  </section>

  <!-- Filters + Table -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filters -->
      <div class="flex flex-wrap gap-2 mb-8">
        <button data-filter="all" class="badge bg-brand-100 dark:bg-brand-900 text-brand-700 dark:text-brand-300 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer active">Tutti</button>
        <button data-filter="Facile" class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-brand-50">Facile</button>
        <button data-filter="Molto facile" class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-brand-50">Molto facile</button>
        <button data-filter="Media" class="badge bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-brand-50">Media</button>
      </div>

      <!-- Table -->
      <div class="table-responsive" id="bonus-table">
        <table>
          <thead>
            <tr>
              <th data-sort="name" class="cursor-pointer hover:text-brand-600">Promozione ↕</th>
              <th data-sort="bonus" class="cursor-pointer hover:text-brand-600">Bonus ↕</th>
              <th>Tipo</th>
              <th>Requisiti</th>
              <th data-sort="expiry" class="cursor-pointer hover:text-brand-600">Scadenza ↕</th>
              <th>Difficoltà</th>
              <th>Codice</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% promos.forEach((promo, i) => { %>
            <tr data-difficulty="<%= promo.difficulty %>">
              <td>
                <div class="flex items-center gap-3 promo-item-<%= i %>" data-col="name">
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style="background: var(--promo-color)">
                    <%= promo.shortName.charAt(0) %>
                  </div>
                  <div>
                    <div class="font-semibold text-gray-900 dark:text-white"><%= promo.name %></div>
                    <div class="text-xs text-gray-500"><%= promo.tagline %></div>
                  </div>
                </div>
              </td>
              <td data-col="bonus">
                <span class="text-xl font-display font-bold text-finance-600 dark:text-finance-400"><%= promo.bonusAmount %>€</span>
              </td>
              <td><span class="badge-blue"><%= promo.bonusType %></span></td>
              <td class="max-w-[180px]">
                <ul class="text-xs space-y-1">
                  <% promo.requirements.forEach(r => { %>
                  <li class="flex items-start gap-1"><span class="text-finance-500 mt-0.5">✓</span> <%= r %></li>
                  <% }) %>
                </ul>
              </td>
              <td data-col="expiry"><%= new Date(promo.validTo).toLocaleDateString('it-IT') %></td>
              <td><span class="badge-green"><%= promo.difficulty %></span></td>
              <td>
                <% if (promo.referralCode) { %>
                <button class="copy-btn text-xs" data-copy="<%= promo.referralCode %>">
                  <span class="copy-code-text"><%= promo.referralCode %></span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                </button>
                <% } else { %>
                <span class="text-xs text-gray-400">Via link</span>
                <% } %>
              </td>
              <td>
                <a href="/bonus/<%= promo.slug %>" class="btn-primary text-xs px-4 py-2">Dettagli →</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Cards mobile-friendly -->
  <section class="py-8 md:hidden">
    <div class="max-w-7xl mx-auto px-4 space-y-4">
      <% promos.forEach((promo, i) => { %>
      <div class="card-promo promo-item-<%= i %>">
        <div class="absolute top-0 left-0 right-0 h-1" style="background: var(--promo-color)"></div>
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm" style="background: var(--promo-color)"><%= promo.shortName.charAt(0) %></div>
            <div>
              <h3 class="font-bold text-gray-900 dark:text-white"><%= promo.name %></h3>
              <span class="badge-green text-[10px]"><%= promo.difficulty %></span>
            </div>
          </div>
          <div class="text-2xl font-display font-bold text-finance-600"><%= promo.bonusAmount %>€</div>
        </div>
        <p class="text-xs text-gray-500 mb-3"><%= promo.description %></p>
        <div class="flex gap-2">
          <% if (promo.referralCode) { %>
          <button class="copy-btn flex-1 justify-center text-xs" data-copy="<%= promo.referralCode %>">
            <span class="copy-code-text"><%= promo.referralCode %></span>
            <span class="copy-label">Copia</span>
          </button>
          <% } %>
          <a href="/bonus/<%= promo.slug %>" class="btn-primary flex-1 text-xs text-center">Guida →</a>
        </div>
      </div>
      <% }) %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
